{
  "name": "amane-stock-manager",
  "version": "0.1.4",
  "description": "Local barcode-based inventory manager with JSON storage, export, and Velopack updates.",
  "author": "Amane Stock Manager",
  "license": "UNLICENSED",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "package:win": "npm run build && electron-packager . \"Amane Stock Manager\" --platform=win32 --arch=x64 --out=dist-packaged --overwrite --prune=true --ignore=\"^/(src|docs|scripts|\\.config|\\.git|Releases|dist-packaged)(/|$)\"",
    "velopack:pack": "powershell -ExecutionPolicy Bypass -File scripts/package-velopack.ps1",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "velopack": "^1.2.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "@swc/core": "^1.15.3",
    "@types/node": "^26.0.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.4.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.5",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
